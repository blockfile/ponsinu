# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# DRY_RUN=true simulates all on-chain calls (safe, no funds touched).
# Set to false ONLY after a funded wallet + RPC are configured and validated.
DRY_RUN=true

# ── Robinhood Chain (EVM) ────────────────────────────────────────────────────
# Defaults target Robinhood Chain mainnet (chain id 4663).
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
# Blockscout instance (REST API, no key needed) used by the preflight check.
EXPLORER_API=https://robinhoodchain.blockscout.com

# Signing wallet: 0x-prefixed hex private key. MUST be the wallet that DEPLOYED
# the token on ponsfamily.com — the locker only lets the deployer claim the
# creator fees. In DRY_RUN you can leave this blank — an ephemeral wallet is
# generated.
WALLET_PRIVATE_KEY=

# ── Pons launchpad (ponsfamily.com, Robinhood Chain) ─────────────────────────
# The PonsLaunchLocker holds the launch LP position and pays the creator share
# of its trading fees via collectFees(token). Claimed fees arrive as WETH + the
# token itself. Leave LOCKER_ADDRESS BLANK — the bot reads the real locker off
# the token's launchFactory() at runtime (factory deployments change; the
# current one is 0x736D76699C26D0d966744cAe304C000d471f7F35). Set it only to
# force a specific locker.
LOCKER_ADDRESS=
# Uniswap V3 SwapRouter02 — buys the token with WETH on the launch pool.
SWAP_ROUTER_ADDRESS=0xCaf681a66D020601342297493863E78C959E5cb2
# WETH — the launch pair token and the claimed fee currency.
WETH_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73

# ── Token ────────────────────────────────────────────────────────────────────
# TOKEN_ADDRESS is YOUR ponsfamily.com token. Its V3 pool, fee tier and pair
# token are read off the token contract at runtime; the creator share of the
# locked-LP trading fees funds the cycle.
TOKEN_ADDRESS=
TOKEN_SYMBOL=PONSINU

# ── Claim → buyback → burn loop ──────────────────────────────────────────────
# Every POLL_SCHEDULE, once the fees reach BURN_ETH_PER_CYCLE, claim them from
# the locker, spend BURN_ETH_PER_CYCLE of WETH buying the token back, and BURN
# the wallet's ENTIRE token balance — the buyback + the token-side fees every
# claim delivers + any residue (send to DEAD_ADDRESS — gone forever).
BURN_ETH_PER_CYCLE=0.01           # WETH bought back + burned each cycle (the trigger threshold)
BURN_USD_PER_CYCLE=5              # USD sizing fallback, used only when BURN_ETH_PER_CYCLE=0
SLIPPAGE_PCT=5                    # V3 buy slippage tolerance, percent (on top of the real quoted fill)
GAS_RESERVE_ETH=0.005             # native ETH floor for gas; auto topped-up by unwrapping WETH
CLAIM_MIN_WETH=0.0005             # skip dust claims below this pending WETH (unless the buy needs it)
BURN_CLAIMED_TOKENS=true          # burn the wallet's whole token balance (false = only the buyback)
# Burn sink for the bought tokens (default is the canonical EVM dead address).
DEAD_ADDRESS=0x000000000000000000000000000000000000dEaD

# ── Trigger ──────────────────────────────────────────────────────────────────
# The scheduler ticks on this timer; each tick claims + buys back + burns
# BURN_ETH_PER_CYCLE once wallet WETH + pending locker fees reach it (else it
# waits) — i.e. one burn per 0.01 ETH of fees. POST /api/run forces a cycle.
POLL_SCHEDULE=*/5 * * * *         # every 5 minutes
# DRY_RUN only: simulated creator fees accrued per tick (so cycles run).
DRY_RUN_FEE_PER_POLL=0.01         # WETH side
DRY_RUN_TOKEN_FEE_PER_POLL=25000  # token side

# ── Market data (optional) ───────────────────────────────────────────────────
# DexScreener chain slug used for /stats market cap; leave default until listed.
DEXSCREENER_CHAIN_ID=robinhood

# ── Storage (MongoDB) ────────────────────────────────────────────────────────
# Local mongod, or a MongoDB Atlas SRV URI (mongodb+srv://user:pass@cluster/...).
MONGODB_URI=
MONGODB_DB=ponsinu

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins that may call the API.
# Use "*" to allow any origin (not recommended). Non-browser calls always pass.
CORS_ORIGINS=

# Secret protecting POST /api/run|pause|resume. Blank = open (dev only).
# In production set a long random string; send it as header x-api-key: <key>.
API_KEY=
